# Module-specific secrets and provider settings will be documented as their
# integrations are introduced. Never expose secrets with a VITE_ prefix.
JARVIS_LOG_LEVEL=info
NODE_ENV=production
JARVIS_IPC_MAX_REQUEST_BYTES=65536
JARVIS_IPC_RATE_LIMIT=120
# Obtain this key from Google AI Studio. It is loaded by Electron Main only.
# GEMINI_API_KEY=
JARVIS_AI_MODEL=gemini-2.5-flash
JARVIS_AI_TIMEOUT_MS=60000
JARVIS_AI_MAX_ATTEMPTS=3
JARVIS_AI_CONTEXT_TOKENS=32000
JARVIS_WEB_TIMEOUT_MS=12000
JARVIS_WEB_MAX_ATTEMPTS=2
JARVIS_WEB_CACHE_TTL_MS=300000
JARVIS_WEB_RATE_LIMIT=120

# Module 11 production hardening.
JARVIS_DEBUG_MODE=false
JARVIS_LOG_MAX_BYTES=1048576
JARVIS_LOG_MAX_FILES=5
JARVIS_DIAGNOSTIC_RETENTION_DAYS=14
JARVIS_BACKUP_RETENTION_DAYS=30
JARVIS_LEAK_THRESHOLD_BYTES=52428800

# Module 12 release engineering.
JARVIS_RELEASE_CHANNEL=stable
# Example: https://updates.example.com/jarvis/stable/latest.json
# JARVIS_UPDATE_MANIFEST_URL=
JARVIS_UNSIGNED_DEVELOPMENT_FALLBACK=true
