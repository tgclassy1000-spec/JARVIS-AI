{
  "name": "jarvis-desktop",
  "version": "0.12.0",
  "private": true,
  "description": "Production-oriented desktop foundation for the J.A.R.V.I.S. AI assistant.",
  "author": "JARVIS Release Engineering",
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "postinstall": "install-electron",
    "dev": "electron-vite dev",
    "start": "electron-vite preview",
    "build": "npm run check && electron-vite build",
    "build:app": "electron-vite build",
    "dist:win": "npm run build && node scripts/release/clean-release-output.mjs && electron-builder --win nsis msi zip && node scripts/release/finalize-release-output.mjs",
    "dist:win:unsigned": "npm run build && node scripts/release/clean-release-output.mjs && set CSC_IDENTITY_AUTO_DISCOVERY=false&& electron-builder --win zip && electron-builder --win msi --prepackaged release/win-unpacked && node scripts/release/build-exe-bootstrap.mjs && node scripts/release/finalize-release-output.mjs",
    "dist:win:exe-bootstrap": "node scripts/release/build-exe-bootstrap.mjs",
    "release:verify-artifacts": "node scripts/release/verify-artifacts.mjs",
    "release:rc": "npm run build && npm run test:coverage && npm run dist:win:unsigned && npm run release:verify-artifacts",
    "verify": "npm run build && npm run test:smoke",
    "check": "npm run typecheck && npm run lint && npm run test:run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest",
    "test:run": "vitest run",
    "test:smoke": "node tests/electron-smoke.mjs",
    "test:coverage": "vitest run tests/platform tests/conversation tests/memory tests/office tests/documents tests/web tests/desktop tests/plugins tests/production tests/release --coverage --pool=threads --maxWorkers=1"
  },
  "build": {
    "appId": "com.jarvis.desktop",
    "productName": "J.A.R.V.I.S.",
    "copyright": "Copyright © 2026 JARVIS",
    "asar": true,
    "compression": "store",
    "npmRebuild": false,
    "directories": {
      "output": "release",
      "buildResources": "build-resources"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "out/main/index.js"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "msi",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build-resources/icon.ico",
      "signAndEditExecutable": true,
      "signExecutable": true,
      "signExts": [
        ".dll"
      ],
      "signtoolOptions": {
        "publisherName": "JARVIS Release Engineering"
      }
    },
    "nsis": {
      "artifactName": "${productName}-Setup-${version}-${arch}.${ext}",
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "J.A.R.V.I.S.",
      "uninstallDisplayName": "J.A.R.V.I.S.",
      "deleteAppDataOnUninstall": false
    },
    "msi": {
      "additionalLightArgs": [
        "-sval"
      ]
    },
    "publish": [
      {
        "provider": "generic",
        "url": "https://updates.example.invalid/jarvis"
      }
    ]
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@google/genai": "^2.10.0",
    "dotenv": "^17.4.2",
    "fflate": "^0.8.3",
    "prism-react-renderer": "^2.4.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.1.10",
    "electron": "^42.6.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^7.3.6",
    "vitest": "^4.1.10"
  }
}
